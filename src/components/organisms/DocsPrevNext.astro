---
import Button from '@components/atoms/Button.astro';
import type { DocEntry } from '@utils/docs';

interface Props {
  prev: DocEntry | null;
  next: DocEntry | null;
}

const { prev, next } = Astro.props;
---

{
	(prev || next) && (
		<nav class="mt-12 flex justify-between border-t border-gray-200 pt-6">
			{prev ? (
				<Button
					variant="primary"
					size="lg"
					as="a"
					href={`/docs/${prev.data.permalink}`}
					class="w-1/3"
				>
					<div class="flex flex-col">
						<p class="text-sm text-gray-500">Previous</p>
						<p class="font-normal">{prev.data.title}</p>
					</div>
				</Button>
			) : (
				<div />
			)}
			{next ? (
				<Button
					variant="primary"
					size="lg"
					as="a"
					href={`/docs/${next.data.permalink}`}
					class="w-1/3"
				>
					<div class="flex flex-col text-right">
						<p class="text-sm text-gray-500">Next</p>
						<p class="font-normal">{next.data.title}</p>
					</div>
				</Button>
			) : (
				<div />
			)}
		</nav>
	)
}
